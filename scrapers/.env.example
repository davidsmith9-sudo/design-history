# Copy to .env (or set as system environment variables) to enable optional sources.
#
# Europeana — free key, sign up at:
#   https://pro.europeana.eu/page/apis (register → "Get your API key")
EUROPEANA_API_KEY=

# Smithsonian Open Access — free api.data.gov key, sign up at:
#   https://api.data.gov/signup/
# (uses the universal data.gov key; also recognized as DATA_GOV_API_KEY)
SMITHSONIAN_API_KEY=

# Met Museum, V&A, DOAJ, Internet Archive — NO key needed
# Wikipedia, Wikidata — NO key needed
# MoMA — run `python run.py moma-import` once instead of using a key

# 百度百科 proxy (optional) — Baidu 對境外 IP 多半 403。
# 設定一個指向中國的 proxy URL,就會只有 Baidu 走這條,其他來源不受影響。
# 範例:
#   BAIDU_PROXY=http://localhost:7890
#   BAIDU_PROXY=socks5://user:pass@host:1080
BAIDU_PROXY=

# 如需所有來源都走同一個 proxy,設 HTTPS_PROXY(requests 標準環境變數):
# HTTPS_PROXY=http://localhost:7890
